<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- AI Personality Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Personality Settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Communication Style"
                    android:textSize="14sp" />

                <Spinner
                    android:id="@+id/spinner_communication_style"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Formality Level"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />

                <SeekBar
                    android:id="@+id/seekbar_formality"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="5"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Casual"
                        android:textSize="12sp"
                        android:gravity="start" />

                    <TextView
                        android:id="@+id/tv_formality_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Formal"
                        android:textSize="12sp"
                        android:gravity="end" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Response Detail Level"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />

                <SeekBar
                    android:id="@+id/seekbar_detail_level"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="7"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Brief"
                        android:textSize="12sp"
                        android:gravity="start" />

                    <TextView
                        android:id="@+id/tv_detail_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="7"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Detailed"
                        android:textSize="12sp"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- AI Behavior Preferences -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Behavior Preferences"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <Switch
                    android:id="@+id/switch_proactive_suggestions"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable proactive suggestions" />

                <Switch
                    android:id="@+id/switch_learning_mode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable learning from interactions"
                    android:layout_marginTop="8dp" />

                <Switch
                    android:id="@+id/switch_context_awareness"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable context awareness"
                    android:layout_marginTop="8dp" />

                <Switch
                    android:id="@+id/switch_humor_enabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable humor in responses"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Creativity Level"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />

                <SeekBar
                    android:id="@+id/seekbar_creativity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="5"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Factual"
                        android:textSize="12sp"
                        android:gravity="start" />

                    <TextView
                        android:id="@+id/tv_creativity_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Creative"
                        android:textSize="12sp"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Specialized Knowledge -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Specialized Knowledge Areas"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select areas where AI should have enhanced knowledge:"
                    android:textSize="14sp" />

                <CheckBox
                    android:id="@+id/checkbox_construction"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Construction & Estimating"
                    android:layout_marginTop="8dp" />

                <CheckBox
                    android:id="@+id/checkbox_materials"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Materials & Pricing"
                    android:layout_marginTop="4dp" />

                <CheckBox
                    android:id="@+id/checkbox_project_management"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Project Management"
                    android:layout_marginTop="4dp" />

                <CheckBox
                    android:id="@+id/checkbox_local_regulations"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Local Regulations"
                    android:layout_marginTop="4dp" />

                <CheckBox
                    android:id="@+id/checkbox_industry_trends"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Industry Trends"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Voice & Audio Settings -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardElevation="4dp"
            app:cardCornerRadius="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice & Audio Settings"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <Switch
                    android:id="@+id/switch_voice_enabled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Enable voice responses" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Type"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />

                <Spinner
                    android:id="@+id/spinner_voice_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Speech Speed"
                    android:textSize="14sp"
                    android:layout_marginTop="12dp" />

                <SeekBar
                    android:id="@+id/seekbar_speech_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:max="10"
                    android:progress="5"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Slow"
                        android:textSize="12sp"
                        android:gravity="start" />

                    <TextView
                        android:id="@+id/tv_speech_speed_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Fast"
                        android:textSize="12sp"
                        android:gravity="end" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
