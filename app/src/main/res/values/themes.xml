<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- EstiMetric App Theme -->
    <style name="Theme.EstiMetric" parent="Theme.AppCompat.Light.DarkActionBar">
        <item name="colorPrimary">@color/primary_purple</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent_teal</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:windowBackground">@color/white</item>
    </style>

    <!-- Material Button Styles -->
    <style name="Widget.EstiMetric.Button.Primary" parent="Widget.AppCompat.Button.Colored">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="Widget.EstiMetric.Button.Secondary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_secondary</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <!-- Card Style -->
    <style name="Widget.EstiMetric.CardView" parent="Widget.AppCompat.CardView">
        <item name="cardBackgroundColor">@color/white</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
    </style>

    <!-- Text Styles -->
    <style name="TextAppearance.EstiMetric.Headline1" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textSize">34sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.EstiMetric.Headline2" parent="TextAppearance.AppCompat.Subheading">
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.EstiMetric.Body" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.EstiMetric.Caption" parent="TextAppearance.AppCompat.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>
</resources>
