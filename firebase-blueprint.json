{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account information and membership tier.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "membershipTier": { 
          "type": "string", 
          "enum": ["Free", "Pro", "Elite", "Enterprise"],
          "description": "The user's current membership level."
        },
        "isBeta": { "type": "boolean", "description": "Flag indicating if the user is part of the beta release." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "membershipTier", "isBeta", "createdAt"]
    },
    "BidData": {
      "title": "Bid Data",
      "description": "A project bid or estimate.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientName": { "type": "string" },
        "projectName": { "type": "string" },
        "projectTier": { "type": "string" },
        "laborCost": { "type": "number" },
        "status": { "type": "string" },
        "date": { "type": "string" },
        "beforePhoto": { "type": "string" },
        "afterMockup": { "type": "string" },
        "textDescription": { "type": "object" },
        "materials": { "type": "array" }
      },
      "required": ["id", "clientName", "projectName", "projectTier", "laborCost", "status", "date"]
    },
    "AppSettings": {
      "title": "App Settings",
      "description": "User preferences and settings.",
      "type": "object",
      "properties": {
        "cameraCountdown": { "type": "number" },
        "defaultProjectTier": { "type": "string" },
        "defaultRemodelStyle": { "type": "string" },
        "defaultLaborCost": { "type": "number" },
        "materialMarkupPercent": { "type": "number" },
        "thinkingBudget": { "type": "string" },
        "preferredVoice": { "type": "string" },
        "autoSnapEdges": { "type": "boolean" },
        "exportFormat": { "type": "string" },
        "bccEmail": { "type": "string" },
        "currencySymbol": { "type": "string" },
        "companyName": { "type": "string" },
        "pricingLocationMode": { "type": "string" },
        "zipCode": { "type": "string" },
        "pricingSource": { "type": "string" },
        "showAmazonComparison": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile documents."
    },
    "users/{userId}/bids/{bidId}": {
      "schema": { "$ref": "#/entities/BidData" },
      "description": "User's saved bids."
    },
    "users/{userId}/settings/preferences": {
      "schema": { "$ref": "#/entities/AppSettings" },
      "description": "User's application settings."
    }
  }
}
